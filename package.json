{
  "name": "daypage-monorepo",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.34.4+sha512.8768be55200ae3f2226b6527fcca2687e14bc4e5f12d7721a0f25da3df47915177058648db4177baf348120fa0ba2752d8d8d93f6beaf1fe64ae18da8de961af",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "web:dev": "pnpm --filter daypage-web dev",
    "web:build": "pnpm --filter daypage-web build",
    "web:lint": "pnpm --filter daypage-web lint",
    "web:typecheck": "pnpm --filter daypage-web typecheck",
    "db:start": "supabase start",
    "db:reset": "supabase db reset",
    "tokens:build": "node --experimental-strip-types design-tokens/generators/to-css.ts && node --experimental-strip-types design-tokens/generators/to-swift.ts",
    "tokens:check": "pnpm tokens:build && git diff --exit-code -- web/src/app/globals.css DayPage/App/DSTokens.swift"
  }
}
