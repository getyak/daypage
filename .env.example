# DayPage environment configuration template
# Copy this file to .env and fill in real values. .env is gitignored.
# scripts/generate_secrets.sh reads this at Xcode build time and emits
# DayPage/Config/GeneratedSecrets.swift (also gitignored).
#
# CI/CD: the full .env content is stored as GitHub Secret ENV_FILE and written
# to disk at step "Write .env file" in testflight.yml — never committed to git.

# Apple Developer Team ID (from developer.apple.com → Membership)
DEVELOPMENT_TEAM=XXXXXXXXXX

# DeepSeek (AI compilation engine — OpenAI-compatible)
# Get your API key at: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-replace-me
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-pro

# OpenRoute api
# --- LLM (OpenRouter) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Speech-to-text (voice memo transcription) ────────────────────────────────
#
# Two providers are supported. VOICE_ASR_PROVIDER picks the default; when the
# selected provider has no key configured, transcription falls back to
# on-device SFSpeechRecognizer (no network, no third-party upload).
#
#   doubao  — 火山引擎 / Volcano Engine (default). Supports BOTH streaming
#             (real-time, 边说边出字) and recorded-file transcription.
#   whisper — OpenAI Whisper. Recorded-file transcription only.
VOICE_ASR_PROVIDER=doubao

# Doubao / 火山引擎 语音识别 (ASR)
# Console: https://console.volcengine.com/speech/app
#
# Under 语音识别大模型 (the 1.0 family — NOT the separate "豆包…模型2.0"
# entries in the sidebar), activate these two services for your app:
#   • 录音文件识别大模型 → 极速版   (resource volc.bigasr.auc_turbo)
#   • 流式语音识别大模型 → 小时版   (resource volc.bigasr.sauc.duration)
# Each is provisioned independently: activating one leaves the other
# returning `403 requested resource not granted`. 小时版 offers a free 试用;
# 并发版 additionally requires purchased concurrency or every connection is
# rejected with `45000292 quota exceeded`. Activation takes ~a minute to
# propagate. Then copy the credentials from the service detail page.
#
# NOTE: these are speech-service credentials — NOT the ark-* key from the
# Ark/方舟 console (https://ark.cn-beijing.volces.com). The two are not
# interchangeable; an ark-* key cannot call the ASR endpoints below.
# SECRET_KEY is currently unused by both endpoints (they authenticate with
# APP_ID + ACCESS_TOKEN headers, no request signing) — kept for completeness.
DOUBAO_ASR_APP_ID=replace-me
DOUBAO_ASR_ACCESS_TOKEN=replace-me
DOUBAO_ASR_SECRET_KEY=replace-me
# Endpoints below are optional — sensible defaults are compiled in. Override
# only if 火山引擎 changes routing or you are pointed at a private deployment.
DOUBAO_ASR_STREAM_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel
DOUBAO_ASR_FILE_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel/recognize/flash

# OpenAI Whisper (speech-to-text for voice memos)
# Get your API key at: https://platform.openai.com/api-keys
OPENAI_WHISPER_API_KEY=sk-replace-me

# OpenWeatherMap (auto weather metadata per memo)
# Get your API key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=replace-me

# Supabase (auth + cloud sync backend)
# Find these at: https://app.supabase.com → Project Settings → API
#
# iOS reads SUPABASE_URL / SUPABASE_ANON_KEY (via scripts/generate_secrets.sh).
# Web (@supabase/ssr) reads NEXT_PUBLIC_SUPABASE_URL / NEXT_PUBLIC_SUPABASE_ANON_KEY
# at build/runtime — keep both pairs in sync (same Project ref + anon key).
SUPABASE_URL=https://replace-me.supabase.co
SUPABASE_ANON_KEY=replace-me
NEXT_PUBLIC_SUPABASE_URL=https://replace-me.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me

# Sentry (crash reporting + performance monitoring)
# Create project at sentry.io → Projects → Create Project → iOS (Cocoa)
# Find DSN at: Project Settings → Client Keys (DSN)
SENTRY_DSN=https://replace-me@oXXXXXX.ingest.sentry.io/XXXXXXX

# GitHub PAT for Kubot (issue auto-creation from in-app feedback)
# Create at: https://github.com/settings/tokens — scope: repo
# Rotate at: https://github.com/settings/tokens (revoke old, generate new)
KUBOT_GITHUB_TOKEN=ghp_replace-me

# Linear (error issue auto-creation via GitHub Actions)
# API key: Settings → API → Personal API keys
LINEAR_API_KEY=lin_api_replace-me
LINEAR_TEAM_ID=replace-me


#RESEND_API_KEY
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

MATCH_PASSWORD


ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_PROJECT_NAME=default
ARK_API_KEY_NAME=your-api-key-name
ARK_API_KEY_RESOURCE_ID=your-api-key-resource-id
ARK_API_KEY=your-ark-api-key

