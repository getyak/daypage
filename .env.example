# DayPage environment configuration template
# Copy this file to .env and fill in real values. .env is gitignored.
# A build-time script (Scripts/generate_secrets.sh, created by US-002)
# transforms this into Config/GeneratedSecrets.swift.

# Apple Developer Team ID (from developer.apple.com → Membership)
DEVELOPMENT_TEAM=XXXXXXXXXX

# Aliyun DashScope (OpenAI-compatible chat completions)
# Used by the daily compilation engine.
DASHSCOPE_API_KEY=sk-replace-me
DASHSCOPE_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
DASHSCOPE_MODEL=qwen3.5-plus

# OpenAI Whisper (speech-to-text for voice memos)
OPENAI_WHISPER_API_KEY=sk-replace-me

# OpenWeatherMap (auto weather metadata per memo)
OPENWEATHER_API_KEY=replace-me

# Sentry (crash reporting + performance monitoring)
# Create project at sentry.io → Projects → Create Project → iOS (Cocoa)
# Find DSN at: Project Settings → Client Keys (DSN)
SENTRY_DSN=https://replace-me@oXXXXXX.ingest.sentry.io/XXXXXXX

# Linear (error issue auto-creation via GitHub Actions)
# Team: DayPage  Team ID: 6f56b048-0155-4f2f-be96-20aa5dafe0a9
# API key: Settings → API → Personal API keys
LINEAR_API_KEY=lin_api_replace-me
LINEAR_TEAM_ID=6f56b048-0155-4f2f-be96-20aa5dafe0a9
