# =============================================================================
# DayPage .gitignore
# 规则来源：GitHub Swift/Xcode 官方模板 + 项目特定规则
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets — 永远不要提交
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
Config/GeneratedSecrets.swift
DayPage/Config/GeneratedSecrets.swift
Config/Secrets.plist
*.cer
*.p12
*.mobileprovision

# -----------------------------------------------------------------------------
# 用户运行时数据（App 运行时写入 Documents/vault/，仓库里不应出现）
# -----------------------------------------------------------------------------
vault/
Documents/vault/

# -----------------------------------------------------------------------------
# Xcode — 用户特定设置（每个开发者本机不同，必须忽略）
# -----------------------------------------------------------------------------
*.xcuserstate
*.xcuserdatad/
xcuserdata/
*.mode1v3
*.mode2v3
*.perspectivev3
*.pbxuser
!default.pbxuser
!default.mode1v3
!default.mode2v3
!default.perspectivev3

# Xcode 工作区里的用户层
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/

# -----------------------------------------------------------------------------
# Xcode 构建产物
# -----------------------------------------------------------------------------
build/
DerivedData/
*.xcarchive/
*.ipa
*.dSYM.zip
*.dSYM
*.app
*.app.dSYM

# -----------------------------------------------------------------------------
# Swift Package Manager
# -----------------------------------------------------------------------------
.build/
.swiftpm/
Packages/
Package.pins
# Package.resolved 一般要提交（锁版本），但如果你的工作流不需要可以忽略
# Package.resolved
*.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/Package.resolved

# -----------------------------------------------------------------------------
# CocoaPods（如果将来用到）
# -----------------------------------------------------------------------------
Pods/
*.xcworkspace
!default.xcworkspace

# -----------------------------------------------------------------------------
# Carthage（如果将来用到）
# -----------------------------------------------------------------------------
Carthage/Build/
Carthage/Checkouts

# -----------------------------------------------------------------------------
# Claude Code 本地配置（team 共享的 commands/agents 可以提交）
# -----------------------------------------------------------------------------
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/worktrees/
.claude/skills/verify-daypage/runs/
.claude/PRPs/

# -----------------------------------------------------------------------------
# fastlane
# -----------------------------------------------------------------------------
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output
fastlane/logs/

# Gemfile.lock 提交到仓库（锁定版本，保证 CI 和本地一致）
# 如果不想提交可取消注释下一行：
# Gemfile.lock

# -----------------------------------------------------------------------------
# 测试覆盖率 / Profiling
# -----------------------------------------------------------------------------
*.gcov
*.gcda
*.gcno
*.profraw
*.profdata
xcov_report/
slather/

# -----------------------------------------------------------------------------
# Playgrounds 缓存
# -----------------------------------------------------------------------------
timeline.xctimeline
playground.xcworkspace

# -----------------------------------------------------------------------------
# Ralph 运行时产物
# -----------------------------------------------------------------------------
ralph/logs/
ralph/screenshots/
ralph/STOP

# -----------------------------------------------------------------------------
# Stitch 设计稿下载（可从 Stitch 项目重新生成，不必入仓）
# -----------------------------------------------------------------------------
design/stitch/html/
design/stitch/screenshots/

# -----------------------------------------------------------------------------
# macOS 系统文件
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes
.fseventsd
.TemporaryItems

# -----------------------------------------------------------------------------
# IDE / 编辑器
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.netrwhist
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# 日志 / 临时文件
# -----------------------------------------------------------------------------
*.log
*.tmp
*.bak
*.orig
*.rej
crash.log

# -----------------------------------------------------------------------------
# Node（如果未来加 JS 工具链如 swift-format 通过 npm 装）
# -----------------------------------------------------------------------------
node_modules/

# -----------------------------------------------------------------------------
# Python（scripts/ 下的辅助脚本，例如 update_testflight_changelog.py）
# -----------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo

# -----------------------------------------------------------------------------
# 显式保留：以下文件即使匹配上面规则也必须入仓
# -----------------------------------------------------------------------------
!.gitkeep
!.env.example
