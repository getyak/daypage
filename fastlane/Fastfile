# 加载根目录 .env 文件（fastlane 默认只读 fastlane/.env）
env_file = File.expand_path("../.env", __dir__)
if File.exist?(env_file)
  File.foreach(env_file) do |line|
    line.strip!
    next if line.empty? || line.start_with?("#")
    key, value = line.split("=", 2)
    ENV[key] = value if key && value
  end
end

default_platform(:ios)

# ─────────────────────────────────────────────────────────────
# App Store Connect API Key（CI 环境优先使用，本地开发可跳过）
# 从环境变量读取，不硬编码任何密钥
# ─────────────────────────────────────────────────────────────
def api_key
  return nil unless ENV["APP_STORE_CONNECT_API_KEY_ID"]

  app_store_connect_api_key(
    key_id:        ENV["APP_STORE_CONNECT_API_KEY_ID"],
    issuer_id:     ENV["APP_STORE_CONNECT_ISSUER_ID"],
    key_content:   ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
    in_house:      false
  )
end

platform :ios do
  # ─────────────────────────────────────────────────────────────
  # Lane: build_app_only
  # 仅构建，不上传（用于 PR 验证）
  # ─────────────────────────────────────────────────────────────
  desc "Build the app (no upload) — for PR validation"
  lane :build_only do
    setup_secrets

    # 用 xcodebuild build 而非 archive，跳过代码签名，仅验证编译通过
    sh(
      "xcodebuild",
      "-scheme",        "DayPage",
      "-project",       "DayPage.xcodeproj",
      "-configuration", "Release",
      "-destination",   "generic/platform=iOS",
      "-sdk",           "iphoneos",
      "CODE_SIGN_IDENTITY=",
      "CODE_SIGNING_REQUIRED=NO",
      "CODE_SIGNING_ALLOWED=NO",
      "clean", "build"
    )
  end

  # ─────────────────────────────────────────────────────────────
  # Lane: beta
  # 构建并上传到 TestFlight
  # 触发：push to main
  # ─────────────────────────────────────────────────────────────
  desc "Build and upload to TestFlight"
  lane :beta do
    setup_secrets
    increment_build

    # CI 使用手动签名（证书和描述文件已在 workflow 中导入）
    # 本地开发若未设置 PROVISIONING_PROFILE_UUID 则回退到自动签名
    use_manual_signing = !ENV["PROVISIONING_PROFILE_UUID"].to_s.empty?

    export_opts = use_manual_signing ? {
      method:                 "app-store",
      signingStyle:           "manual",
      teamID:                 ENV["DEVELOPMENT_TEAM"],
      provisioningProfiles:   { "com.daypage.app" => ENV["PROVISIONING_PROFILE_UUID"] }
    } : {
      method:                 "app-store",
      signingStyle:           "automatic",
      teamID:                 ENV["DEVELOPMENT_TEAM"]
    }

    build_app(
      scheme:           "DayPage",
      project:          "DayPage.xcodeproj",
      configuration:    "Release",
      export_method:    "app-store",
      clean:            true,
      output_directory: "build",
      output_name:      "DayPage.ipa",
      export_options:   export_opts,
      xcargs:           use_manual_signing \
        ? "CODE_SIGN_STYLE=Manual CODE_SIGN_IDENTITY=\"Apple Distribution\" DEVELOPMENT_TEAM=#{ENV['DEVELOPMENT_TEAM']} PROVISIONING_PROFILE_SPECIFIER=#{ENV['PROVISIONING_PROFILE_UUID']}" \
        : "CODE_SIGN_STYLE=Automatic DEVELOPMENT_TEAM=#{ENV['DEVELOPMENT_TEAM']} -allowProvisioningUpdates"
    )

    upload_to_testflight(
      api_key:                          api_key,
      skip_waiting_for_build_processing: true,
      changelog:                         changelog_from_git_commits(
        commits_count: 10,
        pretty:        "- %s"
      )
    )

    notify_success("TestFlight beta uploaded")
  end

  # ─────────────────────────────────────────────────────────────
  # Lane: release
  # 构建并提交 App Store 审核（手动触发）
  # ─────────────────────────────────────────────────────────────
  desc "Build and submit to App Store for review"
  lane :release do
    setup_secrets
    increment_build

    use_manual_signing = !ENV["PROVISIONING_PROFILE_UUID"].to_s.empty?

    export_opts = use_manual_signing ? {
      method:                 "app-store",
      signingStyle:           "manual",
      teamID:                 ENV["DEVELOPMENT_TEAM"],
      provisioningProfiles:   { "com.daypage.app" => ENV["PROVISIONING_PROFILE_UUID"] }
    } : {
      method:                 "app-store",
      signingStyle:           "automatic",
      teamID:                 ENV["DEVELOPMENT_TEAM"]
    }

    build_app(
      scheme:           "DayPage",
      project:          "DayPage.xcodeproj",
      configuration:    "Release",
      export_method:    "app-store",
      clean:            true,
      output_directory: "build",
      output_name:      "DayPage.ipa",
      export_options:   export_opts,
      xcargs:           use_manual_signing \
        ? "CODE_SIGN_STYLE=Manual CODE_SIGN_IDENTITY=\"Apple Distribution\" DEVELOPMENT_TEAM=#{ENV['DEVELOPMENT_TEAM']} PROVISIONING_PROFILE_SPECIFIER=#{ENV['PROVISIONING_PROFILE_UUID']}" \
        : "CODE_SIGN_STYLE=Automatic DEVELOPMENT_TEAM=#{ENV['DEVELOPMENT_TEAM']} -allowProvisioningUpdates"
    )

    upload_to_app_store(
      api_key:              api_key,
      submit_for_review:    true,
      automatic_release:    false,
      force:                true,
      skip_screenshots:     true,
      skip_metadata:        false,
      precheck_include_in_app_purchases: false
    )

    notify_success("App Store submission complete")
  end

  # ─────────────────────────────────────────────────────────────
  # Private helpers
  # ─────────────────────────────────────────────────────────────
  private_lane :setup_secrets do
    # 在 CI 中，通过 GitHub Secrets 写入 .env，再运行脚本生成 GeneratedSecrets.swift
    # generate_secrets.sh 已经集成在 Xcode Build Phase 里，这里不需要重复调用
    UI.message "Secrets will be generated by Xcode Build Phase (generate_secrets.sh)"
  end

  private_lane :increment_build do
    # 用 git commit 数量作为 build number，保证单调递增
    build_number = sh("git rev-list --count HEAD").strip
    increment_build_number(
      build_number: build_number,
      xcodeproj:    "DayPage.xcodeproj"
    )
    UI.message "Build number set to #{build_number}"
  end

  private_lane :notify_success do |message|
    UI.success message
  end

  # 错误处理
  error do |lane, exception|
    UI.error "Lane #{lane} failed: #{exception.message}"
  end
end
